#include <dt-bindings/gpio/gpio.h>

/ {
  sensors {
    compatible = "zmk,keymap-sensors";

    encoder_left: encoder_left {
      compatible = "alps,ec11";
      a-gpios = <&pro_micro A_PIN (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
      b-gpios = <&pro_micro B_PIN (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
    };
  };
};