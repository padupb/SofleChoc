/ {
  sensors {
    compatible = "zmk,keymap-sensors";

    encoder_left: encoder_left {
      compatible = "alps,ec11";
      /* Esses dois números (X e Y) precisam bater com os pinos A e B do seu encoder */
      a-gpios = <&pro_micro X (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
      b-gpios = <&pro_micro Y (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
    };
  };
};