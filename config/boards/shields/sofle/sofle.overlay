/ {
    sensors {
        compatible = "zmk,keymap-sensors";

        encoder_left: encoder_left {
            compatible = "alps,ec11";
            a-gpios = <&pro_micro 4 GPIO_ACTIVE_HIGH>;
            b-gpios = <&pro_micro 5 GPIO_ACTIVE_HIGH>;
        };

        encoder_right: encoder_right {
            compatible = "alps,ec11";
            a-gpios = <&pro_micro 6 GPIO_ACTIVE_HIGH>;
            b-gpios = <&pro_micro 7 GPIO_ACTIVE_HIGH>;
        };
    };
};